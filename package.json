{
  "name": "toasty",
  "version": "1.0.0",
  "description": "AI-powered GitHub assistant with code review and /plan command support",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env development",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "tail:prod": "wrangler tail --env production",
    "start": "probot run ./app.js",
    "start:dev": "nodemon --exec 'probot run ./app.js'"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "python",
    "toasty",
    "code-review",
    "ai",
    "probot",
    "github-app"
  ],
  "author": "OWASP BLT",
  "license": "AGPL-3.0",
  "dependencies": {
    "probot": "^14.2.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "wrangler": "^4.0.0"
  }
}
