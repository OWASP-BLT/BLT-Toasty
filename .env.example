# Django Configuration
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here

# PostgreSQL Database Configuration
POSTGRES_USER=your_db_username
POSTGRES_DB=your_db_name
POSTGRES_PASSWORD=your_db_password

# (Optional / future) Google Gemini API key for AI-powered features.
# Currently not used by the application; uncomment and set when those features are enabled.
# GEMINI_API_KEY=your-gemini-api-key-here
